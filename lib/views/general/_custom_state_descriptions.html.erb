<%# Custom state descriptions for Hong Kong Code on Access to Information %>
<%# Handles both manually settable and calculated statuses %>
<%
  case status
  when 'internal_review_pending'
    text = _('An internal review has been requested. The department should have this reviewed by a directorate officer at least one rank senior to the officer who made the original decision.')
  when 'ombudsman_complaint'
    text = _('A complaint has been lodged with The Ombudsman. They will investigate whether the department properly complied with the Code on Access to Information.')
  when 'payment_required'
    text = _('The department has indicated that <strong>photocopying charges</strong> apply (HK$1.5 per A4 page, HK$1.6 per A3 page). Information will not be released until payment is made.')
  when 'transferred_hk'
    text = _('This request has been <strong>transferred</strong> to another Hong Kong government department. The receiving department should handle the request under the Code on Access to Information.')
  when 'interim_reply_received'
    text = _('The department sent an interim reply. Under the Code, they should provide the information within 21 calendar days of your original request, or up to 51 days in exceptional circumstances with explanation.')
  when 'exceeds_21_days'
    text = _('This request has exceeded the 21 calendar day target response time without explanation. You may wish to send a reminder or request an internal review.')
  else
    raise "unknown status " + status
  end
%>
<%= text.html_safe %>
