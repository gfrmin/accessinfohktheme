# Traditional Chinese (Hong Kong) translations for AccessInfoHK theme.
# Overrides core zh_HK locale where needed for HK-specific terminology.
# Standardises on "查閱資料" (access to information) for request-related terms.
#
# Core locale uses "索取資料" (request/obtain information) — we override
# to "查閱資料" (access/consult information) to align with the English
# "Access to Information" branding.
#
msgid ""
msgstr ""
"Project-Id-Version: AccessInfoHK Theme\n"
"Report-Msgid-Bugs-To: \n"
"Language: zh_HK\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=1; plural=0;\n"

# =============================================
# Custom request statuses (from customstates.rb)
# =============================================

msgid "Internal review pending."
msgstr "內部覆核待處理。"

msgid "Complaint lodged with The Ombudsman."
msgstr "已向申訴專員公署提出投訴。"

msgid "Interim reply received, awaiting final response."
msgstr "已收到中期回覆，正等待最終回覆。"

msgid "Payment required for photocopying charges."
msgstr "需要支付影印費用。"

msgid "Response time exceeded 21 calendar days."
msgstr "回覆時間已超過21個曆日。"

msgid "Transferred to another Hong Kong government department."
msgstr "已轉交香港政府另一部門處理。"

# Short status labels (from customstates.rb)

msgid "Internal review pending"
msgstr "內部覆核待處理"

msgid "Ombudsman complaint"
msgstr "向申訴專員投訴"

msgid "Interim reply received"
msgstr "已收到中期回覆"

msgid "Payment required"
msgstr "需要支付費用"

msgid "Exceeds 21 days"
msgstr "已超過21天"

msgid "Transferred"
msgstr "已轉交"

# Flash messages (from customstates.rb)

msgid "You have requested an internal review. The department should have this reviewed by a directorate officer at least one rank senior to the officer who made the original decision."
msgstr "你已要求進行內部覆核。部門應由至少高於作出原決定的人員一級的首長級人員進行覆核。"

msgid "You have indicated that you've complained to The Ombudsman. They will investigate whether the department properly complied with the Code on Access to Information."
msgstr "你已表示向申訴專員公署提出投訴。他們將調查部門是否適當遵守《公開資料守則》。"

msgid "The department sent an interim reply. Under the Code, they should provide the information within 21 calendar days of your original request, or up to 51 days in exceptional circumstances with explanation."
msgstr "部門已發出中期回覆。根據《守則》，他們應在你原來提出要求後的21個曆日內提供資料，或在特殊情況下並提供解釋的情況下，最多51個曆日內提供資料。"

msgid "The department has indicated that photocopying charges apply (HK$1.5 per A4 page, HK$1.6 per A3 page). Information will not be released until payment is made."
msgstr "部門已表示需要收取影印費用（每張A4紙1.5港元，每張A3紙1.6港元）。在付款前不會發放資料。"

msgid "This request has exceeded the 21 calendar day target response time without explanation. You may wish to send a reminder or request an internal review."
msgstr "此要求已超過21個曆日的目標回覆時間而沒有解釋。你可能希望發送提醒或要求進行內部覆核。"

msgid "Your request has been transferred to another Hong Kong government department. The receiving department should handle your request under the Code on Access to Information."
msgstr "你的要求已轉交至香港政府另一部門。接收部門應根據《公開資料守則》處理你的要求。"

# Custom state descriptions (from _custom_state_descriptions.html.erb)

msgid "An internal review has been requested. The department should have this reviewed by a directorate officer at least one rank senior to the officer who made the original decision."
msgstr "已要求進行內部覆核。部門應由至少高於作出原決定的人員一級的首長級人員進行覆核。"

msgid "A complaint has been lodged with The Ombudsman. They will investigate whether the department properly complied with the Code on Access to Information."
msgstr "已向申訴專員公署提出投訴。他們將調查部門是否適當遵守《公開資料守則》。"

msgid "The department has indicated that <strong>photocopying charges</strong> apply (HK$1.5 per A4 page, HK$1.6 per A3 page). Information will not be released until payment is made."
msgstr "部門已表示需要收取<strong>影印費用</strong>（每張A4紙1.5港元，每張A3紙1.6港元）。在付款前不會發放資料。"

msgid "This request has been <strong>transferred</strong> to another Hong Kong government department. The receiving department should handle the request under the Code on Access to Information."
msgstr "此要求已<strong>轉交</strong>至香港政府另一部門。接收部門應根據《公開資料守則》處理此要求。"

# Error messages (from customstates.rb)

msgid "unknown status "
msgstr "未知狀態 "

# Controller deadline messages

msgid "Department should respond within %{days} calendar days (by %{date})"
msgstr "部門應在%{days}個曆日內回覆（截止日期：%{date}）"

msgid "Target response time is %{days} calendar days (by %{date})"
msgstr "目標回覆時間為%{days}個曆日（截止日期：%{date}）"

msgid "Request overdue. Maximum time is %{days} calendar days (by %{date})"
msgstr "要求已逾期。最長時間為%{days}個曆日（截止日期：%{date}）"

msgid "Request significantly overdue (exceeded 51 calendar day maximum). Consider requesting an internal review or complaining to The Ombudsman."
msgstr "要求嚴重逾期（已超過51個曆日的最長期限）。請考慮要求內部覆核或向申訴專員投訴。"

msgid "This request has exceeded the 51 calendar day maximum under the Code on Access to Information."
msgstr "此要求已超過《公開資料守則》規定的51個曆日最長期限。"

msgid "This request has exceeded the 21 calendar day target response time."
msgstr "此要求已超過21個曆日的目標回覆時間。"

# Hong Kong terminology


# =============================================
# FOI/Freedom of Information overrides
# Core zh_HK uses "索取資料"; we override to "查閱資料"
# =============================================

# --- Legislation model ---

msgid "FOI"
msgstr "查閱資料"

msgid "Freedom of Information"
msgstr "公開資料"

msgid "A Freedom of Information request"
msgstr "查閱資料要求"

msgid "Freedom of Information Act"
msgstr "《公開資料守則》"

# --- Page titles and navigation ---

msgid "Make and browse Freedom of Information (FOI) requests"
msgstr "提出及瀏覽查閱資料要求"

msgid " - view and make Freedom of Information requests"
msgstr " - 檢視和提出查閱資料要求"

msgid "Search Freedom of Information requests, public authorities and users"
msgstr "搜尋查閱資料要求、公共機構及用戶"

msgid "{{user_name}} - Freedom of Information requests"
msgstr "{{user_name}} - 查閱資料要求"

msgid "{{title}} - a Freedom of Information request to {{public_body}}"
msgstr "{{title}} - 向{{public_body}}提出的查閱資料要求"

msgid "FOI in Action"
msgstr "查閱資料實例"

# --- Request listings ---

msgid "FOI requests"
msgstr "查閱資料要求"

msgid "FOI requests by '{{user_name}}'"
msgstr "「{{user_name}}」的查閱資料要求"

msgid "FOI requests {{start_count}} to {{end_count}} of about {{total_count}}"
msgstr "約{{total_count}}項查閱資料要求中的第{{start_count}}到{{end_count}}項"

msgid "One FOI request found"
msgstr "找到一項查閱資料要求"

msgid "About {{count}} FOI requests found"
msgstr "找到約{{count}}項查閱資料要求"

msgid "New Freedom of Information requests"
msgstr "查閱資料的新要求"

msgid "Successful Freedom of Information requests"
msgstr "成功的查閱資料要求"

# --- User profile ---

msgid "Your Freedom of Information request"
msgid_plural "Your Freedom of Information requests (approximately {{count}})"
msgstr[0] "你的查閱資料要求（約{{count}}項）"

msgid "Your {{count}} private Freedom of Information request"
msgid_plural "Your {{count}} private Freedom of Information requests"
msgstr[0] "你的{{count}}個私人查閱資料要求"

msgid "This person's Freedom of Information request"
msgid_plural "This person's Freedom of Information requests (approximately {{count}})"
msgstr[0] "此用戶的查閱資料要求（約{{count}}項）"

msgid "Freedom of Information requests made"
msgstr "已提出的查閱資料要求"

msgid "Freedom of Information requests made by this person"
msgstr "此人曾經提出的查閱資料要求"

msgid "Freedom of Information requests made by you"
msgstr "你曾經提出的查閱資料要求"

msgid "Freedom of Information requests made using this site"
msgstr "透過本站提出的查閱資料要求"

msgid "This person has made no Freedom of Information requests using this site."
msgstr "此人沒有利用此網站提出查閱資料要求。"

msgid "You have made no Freedom of Information requests using this site."
msgstr "你沒有在本站發出過任何查閱資料要求。"

msgid "Nobody has made any Freedom of Information requests to {{public_body_name}} using this site yet."
msgstr "尚沒有人使用本網站向{{public_body_name}}提出查閱資料要求。"

msgid "View Freedom of Information requests made by {{user_name}}:"
msgstr "查看{{user_name}}的查閱資料要求："

msgid "What are you investigating using Freedom of Information?"
msgstr "你希望透過查閱資料了解甚麼？"

# --- Email and notification bodies ---

msgid "Four weeks ago you made a Freedom of Information request to {{public_body_name}} using {{site_name}}."
msgstr "四星期前，你透過{{site_name}}向{{public_body_name}}提出查閱資料要求。"

msgid "A survey about your recent Freedom of Information request"
msgstr "就你近日查閱資料要求的意見調查"

msgid "We would like to know more about you, and your experience making a Freedom of Information request through the site."
msgstr "我們希望更認識你和你使用本網站提出查閱資料要求的經驗。"

msgid "Please pass this on to the person who conducts Freedom of Information reviews."
msgstr "請將此電郵轉送至負責覆檢查閱資料要求的職員。"

msgid "You have the <strong>right</strong> to request information from any publicly-funded body, and get answers. {{site_name}} helps you make a Freedom of Information request. It also publishes all requests online."
msgstr "你<strong>有權</strong>向任何公共機構查閱資料，並得到答案。{{site_name}}幫助你提出查閱資料要求，並在網上發布所有要求。"

# --- Attachment and plain-text views ---

msgid "This is a plain-text version of the Freedom of Information request \"{{request_title}}\".  The latest, full version is available online at {{full_url}}"
msgstr "這是查閱資料要求「{{request_title}}」的純文字版。最新的完整版本可在網上取得，可見於{{full_url}}"

msgid "This is an HTML version of an attachment to the Freedom of Information request"
msgstr "這是查閱資料要求的附件的HTML版本"

# --- Law applicability ---

msgid "FOI law does not apply to this authority."
msgstr "《公開資料守則》不包含此公共機構。"

msgid "Freedom of Information law does not apply to this authority, so you cannot make a request to it."
msgstr "《公開資料守則》不覆蓋此公共機構，你不能要求它披露資料。"

msgid "Freedom of Information law no longer applies to {{public_body_name}}."
msgstr "《公開資料守則》不再覆蓋{{public_body_name}}。"

msgid "The Freedom of Information Act <strong>does not apply</strong> to"
msgstr "《公開資料守則》<strong>不適用</strong>於"

msgid "This authority is not subject to FOI law, so is not legally obliged to respond"
msgstr "此公共機構不受《公開資料守則》規管，因此沒有法律義務回覆"

# --- Search offline ---

msgid "The search index is currently offline, so we can't show the Freedom of Information requests that have been made to this authority."
msgstr "搜尋索引目前離線，因此我們未能顯示曾向此公共機構提出的查閱資料要求。"

msgid "The search index is currently offline, so we can't show the Freedom of Information requests this person has made."
msgstr "搜尋索引目前離線，因此我們未能顯示此人提出的查閱資料要求。"

# --- Citations ---

msgid "Let us know about great examples of <a href=\"{{citations_path}}\">FOI in Action</a>."
msgstr "歡迎告訴我們<a href=\"{{citations_path}}\">查閱資料實例</a>。"

msgid "See more examples of <a href=\"{{citations_path}}\">FOI in Action</a>."
msgstr "查看更多<a href=\"{{citations_path}}\">查閱資料實例</a>。"

# --- Country/regional banners ---

msgid "Hello! You can make Freedom of Information requests within {{country_name}} at {{link_to_website}}"
msgstr "你好！你可以在{{link_to_website}}向{{country_name}}的公營機構查閱資料。"

msgid "Hello! You can make Freedom of Information requests within {{country_name}} at {{link_to_website}} and to EU institutions at {{link_to_asktheeu}}"
msgstr "你好！你可以在{{link_to_website}}向{{country_name}}的公營機構查閱資料或在{{link_to_asktheeu}}向歐盟機構查閱資料。"

msgid "Hello! We have an <a href=\"{{url}}\">important message</a> for visitors in other countries. You can also make Freedom of Information requests to EU institutions at {{link_to_asktheeu}}"
msgstr "你好，外地訪客！你有一則<a href=\"{{url}}\">重要訊息</a>。你可以在{{link_to_asktheeu}}向歐盟機構查閱資料。"

msgid "Hello! We have an <a href=\"{{url}}\">important message</a> for visitors outside {{country_name}}. You can also make Freedom of Information requests to EU institutions at {{link_to_asktheeu}}"
msgstr "你好，{{country_name}}外的訪客！你有一則<a href=\"{{url}}\">重要訊息</a>。你亦可以在{{link_to_asktheeu}}向歐盟機構查閱資料。"
